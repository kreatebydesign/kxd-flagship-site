    "verify:reporting-ingest": "KXD_SERVER_ONLY_SHIM=1 tsx --import ./scripts/shims/register-server-only.mjs scripts/verify-reporting-ingest.ts",
    "verify:executive-panel-metrics": "tsx scripts/verify-executive-panel-metrics.ts",
    "verify:runtime-contract": "tsx scripts/verify-runtime-contract.ts",
    "verify:sales-pipeline": "tsx scripts/verify-sales-pipeline.ts",
    "verify:availability": "tsx scripts/verify-availability.ts",
