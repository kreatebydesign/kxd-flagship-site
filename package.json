    "verify:schedule-work": "tsx scripts/verify-schedule-work.ts",
    "verify:schedule-work:live": "KXD_SERVER_ONLY_SHIM=1 VERIFY_SCHEDULE_WORK_LIVE=1 tsx --import ./scripts/shims/register-server-only.mjs scripts/verify-schedule-work.ts",
    "repair:scheduling-proposals": "KXD_SERVER_ONLY_SHIM=1 tsx --import ./scripts/shims/register-server-only.mjs scripts/repair-active-scheduling-proposals.ts",
