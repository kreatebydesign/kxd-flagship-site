{
  "name": "kxd-rebuild",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "eslint",
    "payload": "cross-env NODE_OPTIONS='--no-deprecation' payload",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "migrate": "cross-env NODE_OPTIONS='--no-deprecation' payload migrate",
    "seed:services": "tsx scripts/seed-services.ts",
    "seed:projects": "tsx scripts/seed-projects.ts",
    "seed:clients": "tsx scripts/seed-clients.ts",
    "seed:executive-profiles": "tsx scripts/seed-executive-client-profiles.ts",
    "seed:primal-experience": "tsx scripts/seed-primal-experience-profile.ts",
    "seed:portal-user": "tsx scripts/seed-portal-user.ts",
    "verify:primal-portal": "tsx scripts/verify-primal-portal-readiness.ts",
    "verify:partnership-briefing": "tsx scripts/verify-partnership-briefing.ts",
    "verify:client-launch": "tsx scripts/verify-client-launch-readiness.ts",
    "verify:scheduling": "tsx scripts/verify-scheduling-domain.ts",
    "verify:calendar": "tsx scripts/verify-google-calendar-read.ts",
    "verify:calendar-write": "KXD_SERVER_ONLY_SHIM=1 tsx --import ./scripts/shims/register-server-only.mjs scripts/verify-calendar-write.ts",
    "verify:calendar-write:live": "KXD_SERVER_ONLY_SHIM=1 VERIFY_CALENDAR_WRITE_LIVE=1 tsx --import ./scripts/shims/register-server-only.mjs scripts/verify-calendar-write.ts",
    "verify:calendar-sync": "KXD_SERVER_ONLY_SHIM=1 tsx --import ./scripts/shims/register-server-only.mjs scripts/verify-calendar-sync.ts",
    "verify:executive-today-calendar": "tsx scripts/verify-executive-today-calendar.ts",
    "verify:executive-intelligence": "tsx scripts/verify-executive-intelligence.ts",
    "verify:reporting-domain": "tsx scripts/verify-reporting-domain.ts",
    "verify:sales-pipeline": "tsx scripts/verify-sales-pipeline.ts",
    "verify:availability": "tsx scripts/verify-availability.ts",
    "verify:availability:live": "KXD_SERVER_ONLY_SHIM=1 VERIFY_AVAILABILITY_LIVE=1 tsx --import ./scripts/shims/register-server-only.mjs scripts/verify-availability.ts",
    "verify:schedule-work": "tsx scripts/verify-schedule-work.ts",
    "verify:schedule-work:live": "KXD_SERVER_ONLY_SHIM=1 VERIFY_SCHEDULE_WORK_LIVE=1 tsx --import ./scripts/shims/register-server-only.mjs scripts/verify-schedule-work.ts",
    "repair:scheduling-proposals": "KXD_SERVER_ONLY_SHIM=1 tsx --import ./scripts/shims/register-server-only.mjs scripts/repair-active-scheduling-proposals.ts",
    "repair:scheduling-proposals:apply": "KXD_SERVER_ONLY_SHIM=1 APPLY=1 tsx --import ./scripts/shims/register-server-only.mjs scripts/repair-active-scheduling-proposals.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.84.1",
    "@payloadcms/db-sqlite": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "@vercel/blob": "^2.6.0",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "graphql": "^16.12.0",
    "next": "16.2.7",
    "payload": "^3.84.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.3.1",
    "undici": "6.26.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "type": "module"
}
