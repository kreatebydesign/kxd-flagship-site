# App
NEXT_PUBLIC_SITE_URL=https://kreatebydesign.com

# Payload
PAYLOAD_SECRET=change-me-to-a-long-random-string
DATABASE_URI=postgres://postgres:password@127.0.0.1:5432/kxd
PAYLOAD_SQLITE_PATH=file:./.payload/kxd.sqlite

# Inquiries
KXD_INQUIRY_EMAIL=matt@kreatebydesign.com

# Stripe (future)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Analytics (browser tags — public)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=
GOOGLE_SITE_VERIFICATION=

# Google Reporting (server-only — Phase 29C GA4 + Search Console)
# Prefer a service account with Analytics Data API + Search Console API enabled.
# Do NOT reuse GOOGLE_CALENDAR_REFRESH_TOKEN — Calendar scopes are different; re-consent required for reporting OAuth.
# Per-client GA4 property ID + Search Console site URL live on Client Infrastructure.
# Per-client reporting entitlements (website-analytics, seo, …) live on Client Experience Profiles.enabledModules.
# See docs/REPORTING-PROVIDERS.md
GOOGLE_REPORTING_SERVICE_ACCOUNT_JSON=
# Aliases: GA4_SERVICE_ACCOUNT_JSON=  GSC_SERVICE_ACCOUNT_JSON=  GOOGLE_APPLICATION_CREDENTIALS=
# Optional OAuth alternative (reporting-specific refresh token with analytics.readonly + webmasters.readonly):
# GOOGLE_REPORTING_CLIENT_ID=
# GOOGLE_REPORTING_CLIENT_SECRET=
# GOOGLE_REPORTING_REFRESH_TOKEN=

# Google Reviews — Places API
# Activate to pull live reviews into the homepage ReviewsSection.
# Without these, the site uses static fallback reviews (safe default).
#
# 1. Create a Google Cloud project and enable "Places API"
# 2. Generate an API key restricted to the Places API
# 3. Find your Place ID: https://developers.google.com/maps/documentation/javascript/examples/places-placeid-finder
#
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
# Email / Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=Kreate by Design <hello@kreatebydesign.com>
# Optional — public portal URL for password reset links (defaults to https://portal.kreatebydesign.com in production)
PORTAL_PUBLIC_URL=https://portal.kreatebydesign.com